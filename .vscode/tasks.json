{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build quadtree",
      "type": "shell",
      "command": "g++",
      "args": [
        "main.cpp",
        "-o",
        "programa.exe",
        "-O1",
        "-Wall",
        "-I",
        "include/",
        "-L",
        "lib/",
        "-lraylib",
        "-lopengl32",
        "-lgdi32",
        "-lwinmm"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}